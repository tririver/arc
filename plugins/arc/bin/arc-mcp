#!/usr/bin/env bash
set -euo pipefail

launcher_version="3"
install_ref_override="${ARC_MCP_INSTALL_REF:-}"
install_repo="${ARC_MCP_INSTALL_REPO:-https://github.com/tririver/arc.git}"
install_source="${ARC_MCP_INSTALL_SOURCE:-auto}"
python_spec="${ARC_MCP_INSTALL_PYTHON:->=3.11}"
uv_bin_override="${ARC_MCP_INSTALLER_UV:-}"
python_bin="${ARC_MCP_INSTALLER_PYTHON:-python3}"

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
plugin_root="$(CDPATH= cd -- "$script_dir/.." && pwd -P)"
default_repo_root="$(CDPATH= cd -- "$plugin_root/../.." && pwd -P)"
repo_root="${ARC_MCP_REPO_ROOT:-$default_repo_root}"
tool_name="${ARC_MCP_TOOL_NAME:-$(basename -- "$0")}"
arc_tools="arc-mcp arc-paper arc-domain arc-llm arc-typeset arc-companion"

case " ${arc_tools} " in
  *" ${tool_name} "*) ;;
  *)
    printf 'Unsupported ARC tool launcher: %s\n' "$tool_name" >&2
    exit 64
    ;;
esac

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

resolve_path() {
  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null && return 0
  fi
  realpath "$1" 2>/dev/null || printf '%s\n' "$1"
}

sanitize_key() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_' | cut -c 1-160
}

first_line() {
  sed -n '1{s/[[:space:]]//g;p;q;}' "$1" 2>/dev/null || true
}

detect_json_revision() {
  metadata_file="$1"
  [ -f "$metadata_file" ] || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  ARC_PLUGIN_ROOT="$plugin_root" python3 - "$metadata_file" <<'PY' 2>/dev/null || true
import json
import os
import sys

metadata_file = sys.argv[1]
plugin_root = os.path.realpath(os.environ["ARC_PLUGIN_ROOT"])

try:
    with open(metadata_file, encoding="utf-8") as handle:
        payload = json.load(handle)
except Exception:
    raise SystemExit(0)

if isinstance(payload, dict):
    revision = payload.get("revision") or payload.get("gitCommitSha")
    if revision:
        print(revision)
        raise SystemExit(0)

plugins = payload.get("plugins") if isinstance(payload, dict) else None
if not isinstance(plugins, dict):
    raise SystemExit(0)

for installs in plugins.values():
    if not isinstance(installs, list):
        continue
    for install in installs:
        if not isinstance(install, dict):
            continue
        install_path = install.get("installPath")
        if install_path and os.path.realpath(install_path) == plugin_root:
            revision = install.get("gitCommitSha") or install.get("revision")
            if revision:
                print(revision)
                raise SystemExit(0)
PY
}

detect_install_ref() {
  ref_file="${plugin_root}/.arc-install-ref"
  if [ -f "$ref_file" ]; then
    first_line "$ref_file"
    return 0
  fi

  for metadata_file in \
    "${plugin_root}/.codex-marketplace-install.json" \
    "${HOME:-}/.claude/plugins/installed_plugins.json"; do
    ref="$(detect_json_revision "$metadata_file")"
    if [ -n "$ref" ]; then
      printf '%s\n' "$ref"
      return 0
    fi
  done
}

if [ -n "$install_ref_override" ]; then
  install_ref="$install_ref_override"
else
  install_ref="$(detect_install_ref)"
  install_ref="${install_ref:-main}"
fi

if ! is_true "${ARC_MCP_LAUNCHER_NO_PATH:-}"; then
  candidate="$(command -v "$tool_name" 2>/dev/null || true)"
  plugin_tool_path="${script_dir}/${tool_name}"
  if [ -n "$candidate" ] \
    && [ "$(resolve_path "$candidate")" != "$(resolve_path "$0")" ] \
    && [ "$(resolve_path "$candidate")" != "$(resolve_path "$plugin_tool_path")" ]; then
    exec "$candidate" "$@"
  fi
fi

if [ -n "${ARC_MCP_RUNTIME_DIR:-}" ]; then
  runtime_dir="${ARC_MCP_RUNTIME_DIR}"
else
  cache_home="${XDG_CACHE_HOME:-${HOME}/.cache}"
  cache_key="$(sanitize_key "${install_repo}@${install_ref}")"
  runtime_dir="${cache_home}/arc/arc-mcp-runtime/v${launcher_version}/${cache_key}"
fi

venv_dir="${runtime_dir}/venv"
ready_file="${runtime_dir}/install.ok"
failed_file="${runtime_dir}/install.failed"
status_file="${runtime_dir}/install.status"
log_file="${runtime_dir}/install.log"
lock_dir="${runtime_dir}/install.lock"

runtime_ready() {
  [ -f "$ready_file" ] && [ -x "${venv_dir}/bin/${tool_name}" ]
}

runtime_failed() {
  [ -f "$failed_file" ] && ! is_true "${ARC_MCP_INSTALL_RETRY:-}"
}

previous_status() {
  status="$(cat "$status_file" 2>/dev/null || true)"
  case "$status" in
    ''|*[!0-9]*) printf '1\n' ;;
    *) printf '%s\n' "$status" ;;
  esac
}

print_install_log_tail() {
  [ -s "$log_file" ] || return 0
  lines="${ARC_MCP_INSTALL_LOG_TAIL_LINES:-40}"
  case "$lines" in
    ''|*[!0-9]*) lines=40 ;;
  esac
  printf 'Install log tail:\n' >&2
  tail -n "$lines" "$log_file" >&2 2>/dev/null || sed -n '$p' "$log_file" >&2
}

print_previous_failure() {
  {
    printf 'Previous ARC MCP runtime install failed; not retrying automatically.\n'
    printf 'Failure marker: %s\n' "$failed_file"
    printf 'Install log: %s\n' "$log_file"
    printf 'Set ARC_MCP_INSTALL_RETRY=1 to retry, or delete the failure marker after fixing the cause.\n'
  } >&2
  print_install_log_tail
}

print_install_failure() {
  {
    printf 'ARC MCP runtime install failed.\n'
    printf 'Install log: %s\n' "$log_file"
    printf 'Set ARC_MCP_INSTALL_RETRY=1 to retry after fixing the cause.\n'
  } >&2
  print_install_log_tail
}

if runtime_ready; then
  exec "${venv_dir}/bin/${tool_name}" "$@"
fi

if runtime_failed; then
  print_previous_failure
  exit "$(previous_status)"
fi

mkdir -p "$runtime_dir"

waited=0
lock_timeout="${ARC_MCP_INSTALL_LOCK_TIMEOUT_SEC:-600}"
while ! mkdir "$lock_dir" 2>/dev/null; do
  if [ "$waited" -ge "$lock_timeout" ]; then
    printf 'Timed out waiting for ARC MCP runtime install lock: %s\n' "$lock_dir" >&2
    exit 75
  fi
  sleep 1
  waited=$((waited + 1))
done
release_lock() {
  rm -rf "$lock_dir"
}
trap release_lock EXIT

if runtime_ready; then
  release_lock
  trap - EXIT
  exec "${venv_dir}/bin/${tool_name}" "$@"
fi

if runtime_failed; then
  print_previous_failure
  exit "$(previous_status)"
fi

resolve_uv_cmd() {
  uv_cmd=()
  if [ -n "$uv_bin_override" ]; then
    if [ -x "$uv_bin_override" ]; then
      uv_cmd=("$uv_bin_override")
      return 0
    fi
    uv_path="$(command -v "$uv_bin_override" 2>/dev/null || true)"
    if [ -n "$uv_path" ]; then
      uv_cmd=("$uv_path")
      return 0
    fi
    return 1
  fi

  for candidate in \
    uv \
    "${HOME:-}/.local/bin/uv" \
    "${HOME:-}/.cargo/bin/uv"; do
    if [ -z "$candidate" ]; then
      continue
    fi
    if [ -x "$candidate" ]; then
      uv_cmd=("$candidate")
      return 0
    fi
    uv_path="$(command -v "$candidate" 2>/dev/null || true)"
    if [ -n "$uv_path" ]; then
      uv_cmd=("$uv_path")
      return 0
    fi
  done

  if command -v python3 >/dev/null 2>&1 && python3 -m uv --version >/dev/null 2>&1; then
    uv_cmd=(python3 -m uv)
    return 0
  fi
  return 1
}

check_python_fallback_version() {
  "$python_bin" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' 2>/dev/null
}

install_with_pip() {
  if ! command -v "$python_bin" >/dev/null 2>&1; then
    printf 'Neither uv nor %s is available to create the ARC MCP runtime.\n' "$python_bin" >&2
    return 127
  fi
  if ! check_python_fallback_version; then
    printf 'Fallback installer requires Python >= 3.11: %s\n' "$python_bin" >&2
    return 127
  fi
  "$python_bin" -m venv "$venv_dir" || return $?
  "${venv_dir}/bin/python" -m pip install "${requirements[@]}" || return $?
}

install_with_uv() {
  "${uv_cmd[@]}" venv "$venv_dir" --python "$python_spec" || return $?
  "${uv_cmd[@]}" pip install --python "${venv_dir}/bin/python" "${requirements[@]}" || return $?
}

install_runtime() {
  if [ "$install_source" != "auto" ] && [ "$install_source" != "local" ] && [ "$install_source" != "git" ]; then
    printf 'ARC_MCP_INSTALL_SOURCE must be one of: auto, local, git\n' >&2
    return 2
  fi

  rm -rf "$venv_dir"

  if { [ "$install_source" = "auto" ] || [ "$install_source" = "local" ]; } \
    && [ -d "${repo_root}/packages/arc-mcp" ] \
    && [ -d "${repo_root}/packages/arc-paper" ]; then
    requirements=(
      "${repo_root}/packages/arc-llm"
      "${repo_root}/packages/arc-paper"
      "${repo_root}/packages/arc-domain"
      "${repo_root}/packages/arc-typeset"
      "${repo_root}/packages/arc-companion"
      "${repo_root}/packages/arc-mcp"
    )
  else
    source_base="git+${install_repo}@${install_ref}"
    requirements=(
      "arc-llm @ ${source_base}#subdirectory=packages/arc-llm"
      "arc-paper @ ${source_base}#subdirectory=packages/arc-paper"
      "arc-domain @ ${source_base}#subdirectory=packages/arc-domain"
      "arc-typeset @ ${source_base}#subdirectory=packages/arc-typeset"
      "arc-companion @ ${source_base}#subdirectory=packages/arc-companion"
      "arc-mcp @ ${source_base}#subdirectory=packages/arc-mcp"
    )
  fi

  if resolve_uv_cmd; then
    install_with_uv || return $?
    installer="uv"
  else
    install_with_pip || return $?
    installer="pip"
  fi

  for expected_tool in $arc_tools; do
    [ -x "${venv_dir}/bin/${expected_tool}" ] || {
      printf 'Missing ARC runtime command after install: %s\n' "$expected_tool" >&2
      return 127
    }
  done
  "${venv_dir}/bin/arc-mcp" --help >/dev/null || return $?
  {
    printf 'repo=%s\n' "$install_repo"
    printf 'ref=%s\n' "$install_ref"
    printf 'source=%s\n' "$install_source"
    printf 'installer=%s\n' "$installer"
    printf 'launcher_version=%s\n' "$launcher_version"
  } > "$ready_file"
}

rm -f "$failed_file" "$status_file"
set +e
install_runtime >"$log_file" 2>&1
install_status=$?
set -e

if [ "$install_status" -ne 0 ]; then
  rm -rf "$venv_dir"
  printf '%s\n' "$install_status" > "$status_file"
  {
    printf 'ARC MCP runtime install failed.\n'
    printf 'Install log: %s\n' "$log_file"
    printf 'Set ARC_MCP_INSTALL_RETRY=1 to retry after fixing the cause.\n'
  } > "$failed_file"
  print_install_failure
  exit "$install_status"
fi

rm -f "$failed_file" "$status_file"
release_lock
trap - EXIT
exec "${venv_dir}/bin/${tool_name}" "$@"
