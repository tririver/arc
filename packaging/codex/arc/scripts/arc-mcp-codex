#!/usr/bin/env bash
set -euo pipefail

export ARC_AGENT_HOST="${ARC_AGENT_HOST:-codex}"
export ARC_LLM_PROVIDER="${ARC_LLM_PROVIDER:-codex-cli}"
export ARC_CODEX_MODEL="${ARC_CODEX_MODEL:-gpt-5.4-mini}"

if [[ -n "${ARC_MCP_COMMAND:-}" ]]; then
  exec "${ARC_MCP_COMMAND}" "$@"
else
  exec arc-mcp "$@"
fi
