{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARC Calculate Report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "proposer_count",
    "max_recalculations",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "const": "arc.calculate.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "proposer_count": {
      "type": "integer",
      "minimum": 1
    },
    "max_recalculations": {
      "type": "integer",
      "minimum": 0
    },
    "human_gate": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"type": "string"},
        "pause_on_statuses": {
          "type": "array",
          "items": {
            "enum": ["reference_disagrees", "two_agree", "all_disagree", "unresolved", "failed"]
          }
        }
      },
      "additionalProperties": true
    },
    "status": {
      "enum": ["completed", "blocked_for_user", "blocked_for_revision", "failed"]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "kind", "status", "attempts"],
        "properties": {
          "step_id": {"type": "string", "minLength": 1},
          "kind": {
            "enum": ["foundation_check", "new_calculation"]
          },
          "status": {
            "enum": ["accepted", "blocked_for_user", "blocked_for_revision", "failed"]
          },
          "attempts": {"type": "array"},
          "accepted_output": {
            "type": ["object", "null"]
          },
          "blocked_output": {
            "type": ["object", "null"]
          },
          "reviewer_consensus": {
            "type": ["object", "null"]
          },
          "check_history": {
            "type": "array",
            "items": {"type": "string"}
          },
          "check_method": {
            "enum": ["analytic", "numerical", "mixed"]
          },
          "numerical_relative_error": {
            "type": ["number", "null"],
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "foundation_versions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_equation_id", "path", "check_history"],
        "properties": {
          "target_equation_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "check_method": {
            "enum": ["analytic", "numerical", "mixed"]
          },
          "numerical_relative_error": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "check_history": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
